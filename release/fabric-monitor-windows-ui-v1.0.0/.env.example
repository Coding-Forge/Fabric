TENANT_ID=""
CLIENT_ID=""
CLIENT_SECRET=""
CLOUD_ENVIRONMENT="Commercial"

# Supported cloud environments:
# Commercial, Gcc, GccHigh, Dod
# Fabric REST API and OneLake output are only enabled for Commercial until Fabric Gov is public preview.

# Comma-separated module names:
# Activity,Apps,Capacity,CapacityMetrics,Catalog,Domains,FabricItems,Gateway,Graph,Refreshables,RefreshHistory,Roles,Tenant,Workspaces
APPLICATION_MODULES="Activity,Apps,Catalog,Graph,Tenant,RefreshHistory,Gateway"

# Standalone local output. If no storage/lakehouse values are set, the app defaults to Data.
OUTPUT_PATH="Data"

# Blob Storage: use either connection string auth or account URL + DefaultAzureCredential.
STORAGE_ACCOUNT_CONNECTION_STRING=""
STORAGE_ACCOUNT_URL=""
STORAGE_ACCOUNT_CONTAINER_NAME=""
STORAGE_ACCOUNT_CONTAINER_ROOT_PATH=""

# Fabric lakehouse / OneLake output.
ON_FABRIC="true"
LAKEHOUSE_NAME=""
WORKSPACE_NAME=""
PATH_IN_LAKEHOUSE=""

ALL_WORKSPACES="false"
EXCLUDE_PERSONAL_WORKSPACES="true"
EXCLUDE_INACTIVE_WORKSPACES="true"

# Graph enrichment for user inactivity, license, and Power BI audience analysis.
GRAPH_EXTRACT_GROUPS="true"
# Optional comma-separated Entra group object IDs used for Power BI app audiences.
# When omitted, all extracted security groups are available as candidate audience groups.
POWER_BI_AUDIENCE_GROUP_IDS=""
